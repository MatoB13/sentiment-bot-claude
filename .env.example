# --- Anthropic (analytik) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# --- Strike Finance API wallet (Ed25519) ---
# Vygeneruj na https://app.strikefinance.org/api-keys
STRIKE_API_PRIVATE_KEY=
STRIKE_API_PUBLIC_KEY=
STRIKE_BASE_URL=https://api.strikefinance.org
# Zisti presný symbol/asset identifikator pre NAS100 cez strike_client.get_markets()
STRIKE_NAS100_SYMBOL=NAS100-USD

# --- Twitter/X (volitelne, plateny tier) ---
ENABLE_TWITTER=false
TWITTER_BEARER_TOKEN=

# --- Databaza ---
# Na Railway pouzi Postgres plugin - SQLite subor sa straca pri redeployi!
DATABASE_URL=sqlite:///trades.db

# --- Trading / risk parametre ---
DRY_RUN=true
TRADE_INTERVAL_HOURS=4
MONITOR_INTERVAL_MINUTES=10
POSITION_MAX_HOURS=24
MIN_CONFIDENCE=65
RISK_PCT=1.0
MAX_LEVERAGE=5
ACCOUNT_BALANCE_USD=1000
