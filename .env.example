# --- Anthropic (analytik) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# --- Strike Finance API wallet (Ed25519) ---
# Vygeneruj na https://app.strikefinance.org/api-keys
STRIKE_API_PRIVATE_KEY=
STRIKE_API_PUBLIC_KEY=
STRIKE_BASE_URL=https://api.strikefinance.org
# Zisti presny symbol/asset identifikator pre kazdy market cez strike_client.get_markets()
STRIKE_NAS100_SYMBOL=NAS100-USD
STRIKE_NVDA_SYMBOL=NVDA-USD
STRIKE_ADA_SYMBOL=ADA-USD

# --- Twitter/X (volitelne, plateny tier) ---
ENABLE_TWITTER=false
TWITTER_BEARER_TOKEN=

# --- Databaza ---
# Na Railway pouzi Postgres plugin - SQLite subor sa straca pri redeployi!
DATABASE_URL=sqlite:///trades.db

# --- Trading / risk parametre - ZDIELANE pre vsetky assety (NAS100/NVDA/ADA bezia v tom istom cykle) ---
DRY_RUN=true
TRADE_INTERVAL_HOURS=4
MONITOR_INTERVAL_MINUTES=10
POSITION_MAX_HOURS=24

# --- NAS100 - risk parametre (povodne, bezpredponove nazvy) ---
MIN_CONFIDENCE=65
# Fixny margin+leverage na kazdy obchod (notional = MARGIN_USD x LEVERAGE)
MARGIN_USD=100
LEVERAGE=40
# Cielove SL/TP ako % od live ceny - Claude navrhuje konkretnu cenu v tolerancii okolo tychto hodnot
DEFAULT_SL_PCT=0.4
DEFAULT_TP_PCT=0.6

# --- NVDA (akcia) - vlastny bot, zapnutelny/vypnutelny, vlastny risk (vyssia
# volatilita ako index -> sirsie SL/TP, nizsia paka) ---
ENABLE_NVDA=true
NVDA_MIN_CONFIDENCE=65
NVDA_MARGIN_USD=100
NVDA_LEVERAGE=10
NVDA_SL_PCT=1.5
NVDA_TP_PCT=2.25

# --- ADA (krypto) - vlastny bot, vlastny risk (najvyssia volatilita -> najsirsie
# SL/TP, najnizsia paka) ---
ENABLE_ADA=true
ADA_MIN_CONFIDENCE=65
ADA_MARGIN_USD=100
ADA_LEVERAGE=6
ADA_SL_PCT=3.5
ADA_TP_PCT=5.25
